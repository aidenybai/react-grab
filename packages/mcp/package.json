{
  "name": "@react-grab/mcp",
  "version": "0.1.32",
  "bin": {
    "react-grab-mcp": "./dist/cli.cjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./dist/*": "./dist/*.js",
    "./dist/*.js": "./dist/*.js"
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "rm -rf dist && NODE_ENV=production vp pack",
    "test": "vp test run",
    "lint": "vp lint",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "clipboardy": "^5.3.1",
    "fkill": "^9.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7"
  }
}
