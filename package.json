{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "cp README.md packages/react-grab/README.md && vp run @react-grab/cli#build && vp run react-grab#build && pnpm --filter grab build",
    "dev": "vp run react-grab#dev",
    "test": "vp run react-grab#test",
    "test:cli": "vp run @react-grab/cli#test",
    "typecheck": "pnpm --filter react-grab typecheck",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "extension:dev": "pnpm --filter web-extension dev",
    "extension:build": "pnpm --filter web-extension build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^25.5.0",
    "@voidzero-dev/vite-plus-core": "^0.1.12",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.12"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "spawn-sync",
      "unrs-resolver"
    ]
  }
}
